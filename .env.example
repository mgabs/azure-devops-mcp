# Azure DevOps MCP Server Configuration

# The full URL to your Azure DevOps Organization (e.g., https://dev.azure.com/MyOrg)
AZURE_DEVOPS_ORG_URL=https://dev.azure.com/YourOrganization

# Option A: Personal Access Token (PAT) - Easiest for local testing
# Scopes needed: Work Items (Read/Write), Code (Read/Write), Build (Read/Write)
AZURE_DEVOPS_PAT=your-personal-access-token

# Option B: Interactive Login / Service Principal (requires Client ID/Secret)
# AZURE_DEVOPS_CLIENT_ID=your-client-id
# AZURE_DEVOPS_CLIENT_SECRET=your-client-secret
# AZURE_DEVOPS_TENANT_ID=common
# CALLBACK_PORT=3000
